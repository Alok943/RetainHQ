{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RetainHQ topic content",
  "type": "object",
  "required": ["slug", "title", "roadmap", "kind", "tier", "metadata", "overview", "why_learning_this", "common_mistakes", "recall_questions", "practice_tasks", "sources"],
  "additionalProperties": false,
  "properties": {
    "slug": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
    "title": { "type": "string", "minLength": 1 },
    "roadmap": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
    "kind": { "enum": ["concept", "milestone"] },
    "tier": { "enum": ["tier1", "tier2", "tier3"] },
    "metadata": {
      "type": "object",
      "required": ["difficulty", "estimated_minutes", "importance", "interview_frequency", "prerequisites", "unlocks", "project_usage"],
      "additionalProperties": false,
      "properties": {
        "difficulty": { "enum": ["easy", "medium", "hard"] },
        "estimated_minutes": { "type": "integer", "minimum": 1, "maximum": 600 },
        "importance": { "type": "integer", "minimum": 1, "maximum": 10 },
        "interview_frequency": { "enum": ["low", "medium", "high"] },
        "prerequisites": { "type": "array", "items": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" } },
        "unlocks": { "type": "array", "items": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" } },
        "project_usage": { "type": "array", "items": { "type": "string" } }
      }
    },
    "overview": {
      "type": "object",
      "required": ["what", "why", "where_used"],
      "additionalProperties": false,
      "properties": {
        "what": { "type": "string", "minLength": 1 },
        "why": { "type": "string", "minLength": 1 },
        "where_used": { "type": "array", "items": { "type": "string" } }
      }
    },
    "why_learning_this": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "common_mistakes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["title", "explanation"],
        "additionalProperties": false,
        "properties": {
          "title": { "type": "string" },
          "explanation": { "type": "string" }
        }
      }
    },
    "recall_questions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["q", "answer"],
        "additionalProperties": false,
        "properties": {
          "q": { "type": "string" },
          "answer": { "type": "string" },
          "tier": { "enum": ["tier1", "tier2", "tier3"] }
        }
      }
    },
    "practice_tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["title", "prompt"],
        "additionalProperties": false,
        "properties": {
          "title": { "type": "string" },
          "prompt": { "type": "string" },
          "starter_code": { "type": "string" },
          "solution": { "type": "string" }
        }
      }
    },
    "code_walkthrough": {
      "type": "object",
      "required": ["code"],
      "additionalProperties": false,
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "focus": { "type": "string" }
      }
    },
    "aha_moment": {
      "type": "object",
      "required": ["code", "prediction", "common_guess", "why"],
      "additionalProperties": false,
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "prediction": { "type": "string", "minLength": 1 },
        "common_guess": { "type": "string", "minLength": 1 },
        "why": { "type": "string", "minLength": 1 }
      }
    },
    "challenge": {
      "type": "object",
      "required": ["title", "prompt"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string" },
        "prompt": { "type": "string" },
        "solution": { "type": "string" }
      }
    },
    "sources": { "type": "array", "minItems": 1, "items": { "type": "string", "format": "uri" } }
  }
}
